# Copy this file to .env and fill in your own values.
# (Requires a package like python-dotenv, or export these in your shell,
# for main.py to pick them up automatically.)

# Get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Long random string used to sign login tokens (JWTs).
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_with_a_long_random_string

# One-time setup key for creating the first admin account via
# POST /api/admin/bootstrap. After you've created your first admin,
# you can leave this set (subsequent admins should be created via
# the /api/admin/users/{id}/promote endpoint instead) or unset it.
ADMIN_SETUP_KEY=change_me
